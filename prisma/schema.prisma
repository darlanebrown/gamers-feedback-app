// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  gamerTag     String   @unique
  displayName  String?
  bio          String?
  role         String   @default("user")
  banned       Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Game {
  slug        String   @id
  title       String   @unique
  coverUrl    String?
  genres      String?
  releaseDate String?
  developer   String?
  metacritic  Int?
  description String?
  fetchedAt   DateTime @default(now())
}

model Review {
  id                   String   @id @default(cuid())
  gameTitle            String
  platform             String
  rating               Int
  headline             String
  body                 String
  pros                 String
  cons                 String
  playtime             String
  reviewerTag          String
  classification       String   @default("pending")
  classificationReason String?
  createdAt            DateTime @default(now())
  embedding            Unsupported("vector(1536)")?
}

model ReviewVote {
  id          String   @id @default(cuid())
  reviewId    String
  voterTag    String
  type        String
  createdAt   DateTime @default(now())

  @@unique([reviewId, voterTag])
}

model Follow {
  id           String   @id @default(cuid())
  followerTag  String
  followingTag String
  createdAt    DateTime @default(now())

  @@unique([followerTag, followingTag])
}

model Alert {
  id          String    @id @default(cuid())
  type        String
  gameTitle   String
  count       Int
  detectedAt  DateTime  @default(now())
  dismissed   Boolean   @default(false)
  dismissedAt DateTime?
}

model Notification {
  id        String   @id @default(cuid())
  userTag   String
  type      String
  actorTag  String?
  reviewId  String?
  gameTitle String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
